RewriteEngine On

# 1. Prevent loop if resource is a real file or directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 2. Rewrite clean URLs to their corresponding HTML files inside /pages
RewriteRule ^login$ pages/login.html [L,QSA]
RewriteRule ^onboarding$ pages/onboarding.html [L,QSA]
RewriteRule ^feedback$ pages/feedback.html [L,QSA]
RewriteRule ^hall-of-fame$ pages/hall-of-fame.html [L,QSA]
RewriteRule ^blog$ pages/blog.html [L,QSA]
RewriteRule ^privacy-policy$ pages/privacy-policy.html [L,QSA]
RewriteRule ^security-policy$ pages/security-policy.html [L,QSA]
RewriteRule ^terms-of-service$ pages/terms-of-service.html [L,QSA]

# 3. Rewrite all Single Page Application (SPA) routes to pages/app.html
RewriteRule ^discover$ pages/app.html [L,QSA]
RewriteRule ^chat$ pages/app.html [L,QSA]
RewriteRule ^grid$ pages/app.html [L,QSA]
RewriteRule ^profile$ pages/app.html [L,QSA]
RewriteRule ^settings$ pages/app.html [L,QSA]
RewriteRule ^ai-diagnostics$ pages/app.html [L,QSA]
RewriteRule ^notifications$ pages/app.html [L,QSA]
RewriteRule ^compatibility$ pages/app.html [L,QSA]
RewriteRule ^communities$ pages/app.html [L,QSA]
RewriteRule ^graph$ pages/app.html [L,QSA]
RewriteRule ^virtual-dates$ pages/app.html [L,QSA]
RewriteRule ^agents$ pages/app.html [L,QSA]
