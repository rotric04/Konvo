{
  "version": 2,
  "headers": [
    {
      "source": "/(auth|login|onboarding)(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' *; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdnjs.cloudflare.com https://static.cloudflareinsights.com https://challenges.cloudflare.com https://cdn.jsdelivr.net https://js.sentry-cdn.com https://browser.sentry-cdn.com https://assets.sentry-cdn.com blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://unpkg.com https://*.tile.openstreetmap.org http://*.basemaps.cartocdn.com https://*.basemaps.cartocdn.com http://basemaps.cartocdn.com https://basemaps.cartocdn.com https://res.cloudinary.com; connect-src 'self' ws: wss: https://formsubmit.co https://unpkg.com https://konvo-u5qb.onrender.com https://nominatim.openstreetmap.org https://challenges.cloudflare.com https://*.tile.openstreetmap.org http://*.basemaps.cartocdn.com https://*.basemaps.cartocdn.com http://basemaps.cartocdn.com https://basemaps.cartocdn.com https://app.posthog.com https://eu.posthog.com https://*.ingest.sentry.io https://sentry.io; frame-src 'self' https://challenges.cloudflare.com; worker-src 'self' blob:; child-src 'self' blob: https://challenges.cloudflare.com; frame-ancestors 'none';"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/auth",
      "missing": [{ "type": "cookie", "key": "cf_clearance" }],
      "destination": "/security-verification.html"
    },
    {
      "source": "/login",
      "missing": [{ "type": "cookie", "key": "cf_clearance" }],
      "destination": "/security-verification.html"
    },
    {
      "source": "/onboarding",
      "missing": [{ "type": "cookie", "key": "cf_clearance" }],
      "destination": "/security-verification.html"
    },
    {
      "source": "/:page(discover|chat|grid|compatibility|communities|graph|profile|virtual-dates|agents|settings)(/.+)?",
      "missing": [{ "type": "cookie", "key": "cf_clearance" }],
      "destination": "/security-verification.html"
    },
    {
      "source": "/blog/:subpath+",
      "missing": [{ "type": "cookie", "key": "cf_clearance" }],
      "destination": "/security-verification.html"
    },
    {
      "source": "/blog",
      "missing": [{ "type": "cookie", "key": "cf_clearance" }],
      "destination": "/security-verification.html"
    },
    {
      "source": "/:page(feedback|admin_dashboard|hall-of-fame|security-policy|privacy-policy|terms-of-service)",
      "missing": [{ "type": "cookie", "key": "cf_clearance" }],
      "destination": "/security-verification.html"
    },
    {
      "source": "/api/:path*",
      "destination": "https://konvo-u5qb.onrender.com/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/:path*"
    },
    {
      "source": "/:file(robots\\.txt|security\\.txt|pgp-key\\.txt|llms\\.txt|llm-full\\.txt|agents\\.json)",
      "destination": "/txt/:file"
    },
    {
      "source": "/.well-known/security.txt",
      "destination": "/txt/security.txt"
    },
    {
      "source": "/.well-known/agents.json",
      "destination": "/txt/agents.json"
    },
    {
      "source": "/llms-full.txt",
      "destination": "/txt/llm-full.txt"
    },
    {
      "source": "/auth",
      "destination": "/pages/login.html"
    },
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/onboarding",
      "destination": "/pages/onboarding.html"
    },
    {
      "source": "/:page(discover|chat|grid|compatibility|communities|graph|profile|virtual-dates|agents|settings)(/.+)?",
      "destination": "/pages/app.html"
    },
    {
      "source": "/blog/:subpath+",
      "destination": "/pages/blog.html"
    },
    {
      "source": "/blog",
      "destination": "/pages/blog.html"
    },
    {
      "source": "/:page(feedback|admin_dashboard|hall-of-fame|security-policy|privacy-policy|terms-of-service)",
      "destination": "/pages/:page.html"
    },
    {
      "source": "/:page([A-Za-z0-9-_]+)",
      "destination": "/pages/:page.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
