{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://konvo-u5qb.onrender.com/api/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/(feedback|auth|admin_dashboard)",
      "destination": "/$1.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
