# Database connection string
DATABASE_URL=sqlite:///./konvodb.db
# Production (Supabase):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# Redis cache
REDIS_URL=redis://localhost:6379/0

# Admin Dashboard
ADMIN_ROUTE_PATH=admin-portal-secured
ADMIN_PASSPHRASE=supersecureadminpass123

# JWT
SECRET_KEY=change_this_to_a_very_long_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=konvo_meili_dev_key

# Celery / Background Worker
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI Avatar Generation (fal.ai)
FAL_API_KEY=your_fal_api_key_here
REPLICATE_API_TOKEN=your_replicate_token_here

# Observability
SENTRY_DSN=https://your_key@sentry.io/project_id
POSTHOG_API_KEY=phk_your_posthog_key

# Supabase (Production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Email (Transactional / Resend)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Konvo <onboarding@resend.dev>

# LinOTP (Optional standard validation endpoint)
LINOTP_API_URL=https://your-linotp-instance.com

# System Environment Mode
ENV=development

# Gemini API Key (Generate at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

