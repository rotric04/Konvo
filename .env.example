# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (python gateway.py): sqlite:///./konvodb.db
# Docker Compose: postgresql://konvo_user:konvo_password@db:5432/konvodb
DATABASE_URL=sqlite:///./konvodb.db
# Production (Supabase):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_ROUTE_PATH=admin-portal-secured
ADMIN_PASSPHRASE=supersecureadminpass123

# ─── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_very_long_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Celery / Background Worker ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Meilisearch (Search fallback — Tier 2) ───────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=konvo_meili_dev_key

# ─── Typesense (Search primary — Tier 1) ──────────────────────────────────────
# Get a free cloud instance at https://cloud.typesense.org/
# Or run self-hosted: docker run -p 8108:8108 typesense/typesense:26.0 ...
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=

# ─── Cloudinary (CDN Image Uploads) ───────────────────────────────────────────
# Sign up at https://cloudinary.com (free tier: 25GB bandwidth/month)
# Without these, avatar uploads fall back to base64 storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Perspective API (Toxicity Moderation) ────────────────────────────────────
# Enable at https://developers.perspectiveapi.com/
# Without this, all content passes through (fail-open).
PERSPECTIVE_API_KEY=

# Toxicity thresholds (optional overrides)
# TOXICITY_BLOCK_THRESHOLD=0.85
# TOXICITY_WARN_THRESHOLD=0.70

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/project_id
POSTHOG_API_KEY=phk_your_posthog_key
APP_VERSION=1.0.0

# ─── AI Integrations ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
FAL_API_KEY=
REPLICATE_API_TOKEN=

# ─── Email (Transactional / Resend) ───────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Konvo <onboarding@resend.dev>

# ─── Turnstile CAPTCHA ────────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ─── System Environment ───────────────────────────────────────────────────────
ENV=development
