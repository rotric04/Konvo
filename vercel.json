{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://konvo-backend-gateway.onrender.com/api/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "/apps/web/$1"
    },
    {
      "source": "/(feedback|auth|admin_dashboard)",
      "destination": "/apps/web/$1.html"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/$1"
    }
  ]
}
